
# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host/dbname?sslmode=require
REDIS_URL=rediss://default:gQAAAAAAAbscAAIgcDIwMDlkMzlhNmY2MTU0ZjlhOGI2YTkyNTMyMWU1OTRhNQ@rested-sheepdog-113436.upstash.io:6379

# Vector store
VECTOR_STORE_TYPE=pgvector
PGVECTOR_COLLECTION=cv_embeddings

# --- LLM Providers (set at least one) ---
LLM__PORTKEY_API_KEY=
LLM__OPENAI_API_KEY=
LLM__GROQ_API_KEY=
LLM__GEMINI_API_KEY=
LLM__OPENROUTER_API_KEY=
LLM__GITHUB_TOKEN=

# LLM preferences
LLM__PREFERRED_PROVIDER=gemini
# JSON array of fallback provider order
LLM__FALLBACK_PROVIDERS=["groq", "openrouter", "gemini"]
LLM__DEFAULT_MODEL=gpt-4o
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=4096

# --- Browser Automation ---
BROWSER__HEADLESS=true
BROWSER__MAX_PARALLEL=3
BROWSER__KEEP_ALIVE=true
BROWSER__MAX_STEPS=50
BROWSER__MAX_FAILURES=3
BROWSER__STEP_TIMEOUT=120
BROWSER__USE_VISION=auto

# --- Job Discovery ---
# Exa AI semantic search for finding jobs across the web (optional)
EXA_API_KEY=1e509fe8-3baa-4d94-8bc9-61edfce04acc

# --- Application Behavior ---
APPLY_MODE=review
# Options: autonomous, review, batch
MIN_ATS_SCORE=0.75
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# --- Platform Credentials ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

INDEED_EMAIL=
INDEED_PASSWORD=

GLASSDOOR_EMAIL=
GLASSDOOR_PASSWORD=
